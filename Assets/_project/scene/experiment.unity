  m_Script: {fileID: 11500000, guid: beabfbbe780af194eac6fbadeac9b228, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TitleScreenUI
  root: {fileID: 2070651469}
  startButton: {fileID: 539827158}
  aboutButton: {fileID: 364733026}
  aboutCloseButton: {fileID: 1071233544}
  aboutRoot: {fileID: 1168985219}
  aboutText: {fileID: 1557053152}
  howToPlayTitle: "\u30B2\u30FC\u30E0\u306E\u904A\u3073\u65B9"
  howToPlayBody: "\u4ED8\u52A0\u9006\u306F\u300E\u69CB\u6587\u69CB\u7BC9\u30ED\u30FC\u30B0\u30E9\u30A4\u30AF\u300F\u3067\u3059\n\u64CD\u4F5C\u306F\u57FA\u672C\u30DE\u30A6\u30B9\u3092\u4F7F\u3063\u3066\u304F\u3060\u3055\u3044\n\u6575\u3001\u5473\u65B9\u306E\u653B\u6483\u306F\u5168\u3066\u69CB\u6587\u3067\u5B9A\u7FA9\u3055\u308C\u3001\u300C\u4E0A\u304B\u3089\u9806\u300D\u306B\u5B9F\u884C\u3057\u307E\u3059\n\u5F37\u5316\u300E\u69CB\u6587\u4ED8\u4E0E\u300F\u3067\u81EA\u5206\u306E\u69CB\u6587\u306B\u300C\u30E9\u30F3\u30C0\u30E0\u306A\u4F4D\u7F6E\u300D\u306B\u52B9\u679C\u3092\u8FFD\u52A0\u3067\u304D\u307E\u3059\n\u300C\u826F\u3044\u52B9\u679C\u300D\u304C\u8FFD\u52A0\u3055\u308C\u308B\u305F\u3073\u306B\u3001\u300C\u60AA\u3044\u52B9\u679C\u300D\u3082\u4ED8\u3044\u3066\u304D\u307E\u3059\n\u52B9\u679C\u306E\u300C\u7D44\u307F\u5408\u308F\u305B\u300D\u3068\u300C\u5B9F\u884C\u9806\u300D\u306B\u3088\u3063\u3066\u3001\u60AA\u3044\u52B9\u679C\u3082\u6709\u5229\u306B\u50CD\u304D\u307E\u3059\n15\u5C64\u3092\u7A81\u7834\u3059\u308B\u3053\u3068\u3067\u30AF\u30EA\u30A2\u3068\u306A\u308A\u307E\u3059"
  creditsTitle: "\u30AF\u30EC\u30B8\u30C3\u30C8"
  creditsBody: "\u30B2\u30FC\u30E0\u3092\u4F5C\u3063\u305F\u4EBA\uFF1A\u30EB\u30C7\u30A3\u30A2(Twitter/X:
    @_Rudia)\n\u30B9\u30D7\u30E9\u30A4\u30C8\u63CF\u304F\u4EBA\u30FB\u97F3\u697D\u4F5C\u308B\u4EBA\u30FB\u30C6\u30B9\u30C8\u30D7\u30EC\u30A4\u30E4\u30FC\uFF1A\u52DF\u96C6\u4E2D\n\u9023\u7D61\u5148\uFF1Arudiarecord@outlook.com\n\n\u30E9\u30A4\u30BB\u30F3\u30B9\u60C5\u5831\nUnity
    Engine: Copyright 2025 Unity Technologies\nDOTween: Copyright Daniele Giardini
    (Demigiant).\nNoto Serif JP: Copyright 2012 Google Inc. All Rights Reserved.
